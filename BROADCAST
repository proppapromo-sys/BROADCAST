class Sensor(ABC):
    """👂 PERCEIVE — where the world enters. Returns the things you could act on now."""
    @abstractmethod
    def perceive(self) -> list:
        ...


class Belief:
    """🧠 a MODEL's output: an estimate + how sure it is (0..1). Confidence drives sizing
    and honesty — an unsure belief must not move size like a sure one."""
    __slots__ = ("value", "confidence", "extra")

    def __init__(self, value, confidence=0.5, **extra):
        self.value = float(value)
        self.confidence = max(0.0, min(1.0, float(confidence)))
        self.extra = extra


class Model(ABC):
    """🧠 BELIEVE — your estimate of the world, with a confidence. This is the hard 95%;
    the framework does NOT solve it. If you can't beat a naive baseline out-of-sample, the
    honest output is low confidence — which the machine will correctly size toward zero."""
    @abstractmethod
    def estimate(self, obs) -> Belief:
        ...


class Objective(ABC):
    """🎯 WANT — how good is this option, given the belief? The goal/utility to maximise.
    Return ≤ 0 to mean 'not worth it' (a first-class, common, correct result)."""
    @abstractmethod
    def utility(self, obs, belief: Belief) -> float:
        ...


class Policy(ABC):
    """⚖️ DECIDE — how big a commitment does this option deserve, in [0, 1] of the per-action
    capacity? (The machine then applies the universal haircuts, control, budget and caps.)"""
    @abstractmethod
    def weight(self, obs, belief: Belief, utility: float) -> float:
        ...


class Actuator(ABC):
    """✋ ACT — confirm-first. Dry-run unless live=True. Return a result object the Critic
    can score; the action (even dry) IS part of the record."""
    @abstractmethod
    def act(self, obs, amount, live=False):
        ...


class Critic(ABC):
    """📈 VALIDATE — did it work? Score a completed action forward (>0 good). The Critic is
    the SWITCH that unlocks real action (law 3) — not a number you print and ignore."""
    @abstractmethod
    def score(self, obs, result) -> float:
        ...


