    print("  learned trust:", {k: round(v, 2) for k, v in m.trust_table.items()})
    m.cycle(act=True, live=True)
    print("  validated? %s (n=%d)" % (m.proven(), len(m._proof)))

    print("\ncycle 3 — a big harm settles → governor trips the kill-switch → brain HALTs:")
    gov.record(-120)
