class Memory:
    """📓 the append-only record (law 4). File-backed (compounds between runs) or in-memory."""
    def __init__(self, path=None):
        self.path = path
        self._mem = [] if path is None else None

    def append(self, rec: dict) -> dict:
        rec = dict(rec); rec.setdefault("ts", round(time.time(), 3))
        if self.path is None:
            self._mem.append(rec)
        else:
            with open(self.path, "a", encoding="utf-8") as fh:
                fh.write(json.dumps(rec) + "\n")
        return rec

    def read(self) -> list:
        if self.path is None:
            return list(self._mem)
        if not os.path.exists(self.path):
            return []
        out = []
        with open(self.path, encoding="utf-8") as fh:
            for line in fh:
                line = line.strip()
                if line:
                    try:
                        out.append(json.loads(line))
                    except ValueError:
                        pass
        return out


def shrink(wins, n, prior=0.5, weight=10.0) -> float:
    """Bayesian-shrunk success rate: pulls a thin sample toward the prior so one lucky hit
    can't earn trust. The atom of all learning here."""
    return (wins + prior * weight) / (n + weight) if (n + weight) else prior


def trust_by(records, field, prior=0.5, weight=10.0) -> dict:
    """Earned trust per value of `field` (e.g. category) from decision/outcome records."""
    by_id = {r.get("id"): r.get(field) for r in records if r.get("kind") == "decision"}
    wins, total = {}, {}
    for r in records:
        if r.get("kind") != "outcome":
            continue
        k = r.get(field) or by_id.get(r.get("id"))
        if not k:
            continue
        wins[k] = wins.get(k, 0.0) + (1.0 if (r.get("score") or 0) > 0 else 0.0)
        total[k] = total.get(k, 0) + 1
    return {k: shrink(wins[k], n, prior, weight) for k, n in total.items()}


