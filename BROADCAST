class Context:
    """🧠↔ the shared NERVOUS SYSTEM. One object every part reads and writes each cycle, so
    the Brain talks to every part and the parts talk to each other."""
    def __init__(self):
        self.posture = "RUN"
        self.state, self.roles, self.directives = {}, {}, {}

    def report(self, who, reading):
        self.state[who] = reading; return reading

    def sense(self, who, default=None):
        return self.state.get(who, default)

    def directive(self, key, default=None):
        return self.directives.get(key, default)


class Brain:
    """🧠 CENTRAL INTELLIGENCE — the conductor. Reads every part through the Context and sets
    ONE posture the whole system obeys; roles REASSIGN to keep it advancing in control.
      ADVANCE  — healthy + improving → full effort, lean offense
      RUN      — steady → normal
      GUARD    — degrading → protect, only act on a strong signal (no speculative new work)
      HALT     — unsafe (killed / breaker) → freeze; finish/clean up only
    Generic and domain-free: 'health' and 'trajectory' are whatever your domain reports."""
    POSTURES = ("ADVANCE", "RUN", "GUARD", "HALT")
    ROLES = {
        "ADVANCE": {"Policy": "offense",   "Model": "trust",   "Controller": "aim-up",   "Actuator": "build"},
        "RUN":     {"Policy": "steady",    "Model": "watch",   "Controller": "center",   "Actuator": "hold"},
        "GUARD":   {"Policy": "selective", "Model": "skeptic", "Controller": "contract", "Actuator": "protect"},
        "HALT":    {"Policy": "frozen",    "Model": "skeptic", "Controller": "hold",     "Actuator": "cleanup"},
    }

    def assess(self, ctx: Context):
        traj = ctx.sense("trajectory", {}) or {}
        sysr = ctx.sense("system", {}) or {}
        adv, health = traj.get("ascent", 0.0), sysr.get("health", 1.0)
        if sysr.get("killed") or sysr.get("unsafe"):
            posture, size, gate = "HALT", 0.0, "none"
        elif adv < -0.05 or health < 0.5:
            posture, size, gate = "GUARD", 0.5, "strong-only"
        elif adv > 0.15 and health > 0.7:
            posture, size, gate = "ADVANCE", 1.0, "all"
        else:
            posture, size, gate = "RUN", 1.0, "all"
        ctx.posture = posture
        ctx.directives = {"size_mult": size, "gate": gate}
        ctx.roles = dict(self.ROLES[posture])
        return posture, ctx.directives


