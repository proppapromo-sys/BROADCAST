#  HELPERS — sanity, anticipation, cost-benefit, the haircuts
# ══════════════════════════════════════════════════════════════════════════════

def sane(obs, nonneg=("cost", "size", "price", "amount", "quantity")) -> str:
    """Reason string if the observation is impossible to act on, else None (sanity gate)."""
    for k in nonneg:
        if k in obs:
            v = obs[k]
            if isinstance(v, bool) or not isinstance(v, (int, float)) or not math.isfinite(v) or v < 0:
                return "%s invalid (%r)" % (k, v)
    return None


def trajectory(series) -> float:
    """⏱️ LEAD THE TARGET — velocity + ½·acceleration of a series (where it's GOING, not where
    it is). >0 heading up. Use it to anticipate instead of chasing the snapshot."""
    if not series or len(series) < 11 or series[-6] == 0 or series[-11] == 0:
        return 0.0
    v = series[-1] / series[-6] - 1.0
    return v + 0.5 * (v - (series[-6] / series[-11] - 1.0))


def clears_cost(benefit, cost, mult=1.0) -> bool:
    """💵 BEAT YOUR VIG — only act if the benefit clears the cost of acting (× a safety margin)."""
    return benefit >= cost * mult


def confidence_haircut(confidence, floor=0.0) -> float:
    """Shrink size by how SURE the belief is (confidence 0..1). Don't bet a guess like a fact."""
    return max(floor, min(1.0, confidence))


def proof_haircut(trust, floor=0.25) -> float:
    """Shrink size by how PROVEN the category is (trust 0.5 = unproven → toward floor; 1 → full).
    Floor is >0 on purpose: pure-zero would deadlock learning (you must act a little to learn)."""
    return max(floor, min(1.0, 2.0 * (trust - 0.5)))


# ══════════════════════════════════════════════════════════════════════════════
#  THE MACHINE — the universal loop
# ══════════════════════════════════════════════════════════════════════════════

class Machine:
    def __init__(self, sensor: Sensor, model: Model, objective: Objective, policy: Policy,
                 actuator: Actuator, governor: Governor, critic: Critic = None, memory: Memory = None,
                 brain: Brain = None, controller: Controller = None, budget: Budget = None,
                 name="system", min_proof=20, trust_table=None):
        self.sensor, self.model, self.objective, self.policy, self.actuator = sensor, model, objective, policy, actuator
        self.governor, self.critic, self.memory = governor, critic, memory
        self.brain, self.controller, self.budget = brain, controller, budget
        self.name, self.min_proof = name, min_proof
        self.trust_table = dict(trust_table or {})     # category → earned trust (learned)
        self._proof = []                                # the Critic's forward scores
        self.ctx = Context()

    # — the Critic is the SWITCH that unlocks real action (law 3) —
    def proven(self):
        if not self.critic or len(self._proof) < self.min_proof:
            return False
        return (sum(self._proof) / len(self._proof)) > 0

    def relearn(self):
        """Turn the record into earned trust (call between runs / periodically)."""
        if self.memory is not None:
            self.trust_table = trust_by(self.memory.read(), "category")
        return self.trust_table

    def _confer(self):
        if not self.brain:
            return {"gate": "all", "size_mult": 1.0}
        g = self.governor
        self.ctx.report("system", {"killed": g.killed, "unsafe": g.tripped(),
                                   "health": self.ctx.sense("system", {}).get("health", 1.0)})
        self.ctx.report("trajectory", {"ascent": self.ctx.sense("trajectory", {}).get("ascent", 0.0)})
        posture, directives = self.brain.assess(self.ctx)
        print("  🧠 posture: %s — roles %s" % (posture, self.ctx.roles))
        return directives

    def cycle(self, act=False, live=False):
        d = self._confer()
        gate, size_mult = d.get("gate", "all"), d.get("size_mult", 1.0)
        go_live = live and self.proven()
        if live and not go_live:
            print("  📈 LIVE BLOCKED — not validated (critic n=%d/%d, mean must be >0). Dry-run." % (len(self._proof), self.min_proof))
        per = self.governor.capacity * self.governor.max_per      # most resource per action
        plans = []
        for obs in self.sensor.perceive():
            oid = obs.get("id", "?")
            bad = sane(obs)
            if bad:
                print("  drop  %-12s — ⚠️ %s" % (oid, bad)); continue
            ok, why = self.governor.allow()
            if not ok:
                print("  HALT  %-12s — ❤️ %s" % (oid, why)); continue
            if gate == "none":
                print("  hold  %-12s — 🧠 %s (freeze)" % (oid, self.ctx.posture)); continue
            belief = self.model.estimate(obs)
            util = self.objective.utility(obs, belief)
            if util <= 0:
                print("  pass  %-12s — 🎯 no value (util %.3f)" % (oid, util)); continue
            if gate == "strong-only" and belief.confidence < 0.66:
                print("  watch %-12s — 🧠 GUARD (only strong signals; conf %.2f)" % (oid, belief.confidence)); continue
            # — the universal sizing chain: intent × honesty × proof × homeostasis × brain —
            trust = self.trust_table.get(obs.get("category"), 0.5)
            commit = self.policy.weight(obs, belief, util)
            commit *= confidence_haircut(belief.confidence)        # don't trust a guess
            commit *= proof_haircut(trust)                          # don't trust the unproven
            if self.controller and self.budget:
                commit *= self.controller.correction(self.budget.load())   # ⚖️ stay centered
            commit *= size_mult                                     # 🧠 brain modulation
            amount = round(max(0.0, min(commit, 1.0)) * per, 2)      # per = capacity × max_per (the hard per-action cap)
            if amount <= 0:
                print("  pass  %-12s — size 0 (haircut)" % oid); continue
            if self.budget is not None and not self.budget.can_commit(amount):
                print("  pass  %-12s — 💰 budget full (free %.2f)" % (oid, self.budget.free)); continue
            if self.budget is not None:
                self.budget.commit(amount)
            print("  🎯 %-12s value %.2f · conf %.2f · trust %.2f → commit %.2f" % (oid, util, belief.confidence, trust, amount))
            plans.append((obs, amount))
            if self.memory is not None:
                self.memory.append({"kind": "decision", "id": oid, "category": obs.get("category"), "amount": amount, "util": util})
        if act:
            for obs, amount in plans:
                result = self.actuator.act(obs, amount, live=go_live)
                if self.critic is not None:
                    sc = self.critic.score(obs, result)
                    self._proof.append(sc)
                    if self.memory is not None:
                        self.memory.append({"kind": "outcome", "id": obs.get("id"), "category": obs.get("category"), "score": sc})
        return plans

    def run_forever(self, interval_s=300, is_open=lambda: True, act=True, live=False):
        while True:
            try:
                if is_open():
                    print("── %s cycle ──" % self.name)
                    self.cycle(act=act, live=live)
                time.sleep(interval_s)
            except KeyboardInterrupt:
                return
            except Exception as ex:
                print("cycle error (continuing):", ex); time.sleep(30)


