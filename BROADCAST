class Controller:
    """⚖️ HOMEOSTASIS — the restoring force. Holds a measured quantity at an AIMED setpoint
    (not a flat one): a moving-target P-controller. Where a Governor is a WALL, this is the
    SPRING that keeps you centered so you rarely reach the wall. retarget() it toward your
    goal; correction() returns a multiplier (≤1 restrains; >1 only if ceil>1, to thrust)."""
    def __init__(self, target, gain=0.8, tol=0.0, floor=0.0, ceil=1.0):
        self.target, self.gain, self.tol = float(target), float(gain), float(tol)
        self.floor, self.ceil = float(floor), float(ceil)

    def retarget(self, target):
        self.target = float(target); return self

    def correction(self, measured, span=None) -> float:
        e = measured - self.target
        if abs(e) <= self.tol:
            return min(self.ceil, max(self.floor, 1.0))
        s = span if span else (abs(self.target) or 1.0)
        return max(self.floor, min(self.ceil, 1.0 - self.gain * (e / s)))


class Budget:
    """💰 ONE shared resource cap across all actions (money, compute, slots, attention).
    The wall the Heart can't over-commit."""
    def __init__(self, cap):
        self.cap = float(cap); self.committed = 0.0

    @property
    def free(self):
        return max(0.0, self.cap - self.committed)

    def load(self):
        return (self.committed / self.cap) if self.cap else 0.0

    def can_commit(self, amount):
        return amount <= self.free + 1e-9

    def commit(self, amount):
        self.committed += amount; return self.committed

    def release(self):
        self.committed = 0.0


class Governor:
    """❤️ SAFETY — domain-agnostic and BUILT FIRST. A per-action cap, a circuit breaker on
    cumulative harm this period, a kill-switch, and `capacity` (the total resource, which
    COMPOUNDS as outcomes settle). record(delta) is what makes the guard real — a guard
    nothing writes to reads as safe but isn't."""
    def __init__(self, capacity, max_per=0.1, harm_limit=0.10):
        self.capacity = float(capacity)        # total resource — grows/shrinks with outcomes
        self.max_per = max_per                  # most of capacity any single action may use
        self.harm_limit = harm_limit            # circuit breaker: stop the period past this loss
        self.period_pnl = 0.0
        self.period_open = float(capacity)
        self.killed = False

    def new_period(self, capacity=None):
        if capacity is not None:
            self.capacity = float(capacity)
        self.period_pnl = 0.0
        self.period_open = self.capacity
        self.killed = False
        return self

    def tripped(self):
        return self.period_open > 0 and self.period_pnl <= -self.harm_limit * self.period_open

    def allow(self):
        if self.killed:
            return (False, "kill-switch active")
        if self.tripped():
            return (False, "circuit breaker (harm limit)")
        return (True, "")

    def record(self, delta):
        """Settle a realized outcome → capacity (compounding), the period ledger, and the
        kill-switch. THIS closes the loop: next action sizes off updated capacity."""
        self.period_pnl += delta
        self.capacity = max(0.0, self.capacity + delta)
        if self.tripped():
            self.killed = True
        return self.killed


